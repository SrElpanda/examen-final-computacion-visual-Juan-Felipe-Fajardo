  m_EditorClassIdentifier: Assembly-CSharp::InteraccionHermes
  textoUI: {fileID: 522620875}
  mensajeDeInformacion: "Hermes con el ni\xF1o Dioniso es una escultura griega de
    m\xE1rmol con una altura de 2,13 metros que se encuentra en el Museo Arqueol\xF3gico
    de Olimpia. Su autor\xEDa se atribuye al escultor Prax\xEDteles del per\xEDodo
    cl\xE1sico final"
